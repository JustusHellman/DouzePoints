rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: game_stats
    // Document ID: {date}_{gameType} (e.g., 2026-03-12_word_game)
    // Fields:
    //   - gameType: string (required)
    //   - date: string (required, YYYY-MM-DD)
    //   - distribution: map (required)
    //       - "12": number
    //       - "10": number
    //       - "8": number
    //       - "6": number
    //       - "4": number
    //       - "2": number
    //       - "0": number
    //   - totalPlayed: number (required)
    //   - lastUpdated: timestamp (required)
    //
    // Collection: support_clicks
    // Document ID: {date} (e.g., 2026-03-12)
    // Fields:
    //   - date: string (required, YYYY-MM-DD)
    //   - count: number (required)
    //   - lastUpdated: timestamp (required)
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && request.auth.token.email_verified == true &&
        (request.auth.token.email == "justusmhellman@gmail.com" ||
         request.auth.token.email == "justus.jo.li@gmail.com" ||
         request.auth.token.email == "douzepointsgame@gmail.com");
    }

    function isValidStatsDoc(data) {
      return data.gameType is string &&
             data.date is string &&
             data.date.matches("^\\d{4}-\\d{2}-\\d{2}$") &&
             data.distribution is map &&
             data.totalPlayed is number &&
             data.lastUpdated is timestamp;
    }

    function isValidSupportClicksDoc(data) {
      return data.date is string &&
             data.date.matches("^\\d{4}-\\d{2}-\\d{2}$") &&
             data.count is number &&
             (!('sources' in data) || data.sources is map) &&
             data.lastUpdated is timestamp;
    }

    function isValidShareClicksDoc(data) {
      return data.date is string &&
             data.date.matches("^\\d{4}-\\d{2}-\\d{2}$") &&
             data.count is number &&
             (!('sources' in data) || data.sources is map) &&
             data.lastUpdated is timestamp;
    }

    function isValidLanguageStatsDoc(data) {
      return data.date is string &&
             data.date.matches("^\\d{4}-\\d{2}-\\d{2}$") &&
             data.total is number &&
             (!('languages' in data) || data.languages is map) &&
             data.lastUpdated is timestamp;
    }

    function isValidCompletionStatsDoc(data) {
      return data.date is string &&
             data.date.matches("^\\d{4}-\\d{2}-\\d{2}$") &&
             data.totalCompleted is number &&
             (!('distribution' in data) || data.distribution is map) &&
             data.lastUpdated is timestamp;
    }

    function isValidDiscoveryStatsDoc(data) {
      return data.date is string &&
             data.date.matches("^\\d{4}-\\d{2}-\\d{2}$") &&
             (!('count' in data) || data.count is number) &&
             data.lastUpdated is timestamp;
    }

    function isValidInfiniteDailyStatsDoc(data) {
      return data.date is string &&
             data.date.matches("^\\d{4}-\\d{2}-\\d{2}$") &&
             data.gameId is string &&
             data.difficulty is string &&
             (!('totalStarts' in data) || data.totalStarts is number) &&
             (!('totalCompletions' in data) || data.totalCompletions is number) &&
             (!('totalLosses' in data) || data.totalLosses is number) &&
             (!('totalScore' in data) || data.totalScore is number) &&
             (!('totalStreak' in data) || data.totalStreak is number) &&
             data.lastUpdated is timestamp;
    }

    function isValidInfiniteRunDoc(data) {
      return data.gameId is string &&
             data.difficulty is string &&
             data.score is number &&
             data.streak is number &&
             data.wasCompleted is bool &&
             data.timestamp is timestamp;
    }

    match /game_stats/{statsId} {
      // Only the admin can see the global stats
      allow read: if isAdmin();
      
      // Anyone can report a score (create or update)
      // We validate the schema to prevent junk data
      allow create: if isValidStatsDoc(request.resource.data);
      
      // For updates, we ensure they are only incrementing and not changing metadata
      allow update: if isValidStatsDoc(request.resource.data) &&
                      request.resource.data.gameType == resource.data.gameType &&
                      request.resource.data.date == resource.data.date;
    }

    match /support_clicks/{dateId} {
      allow read: if isAdmin();
      
      allow create: if isValidSupportClicksDoc(request.resource.data);
      
      allow update: if isValidSupportClicksDoc(request.resource.data) &&
                      request.resource.data.date == resource.data.date;
    }

    match /share_clicks/{dateId} {
      allow read: if isAdmin();
      
      allow create: if isValidShareClicksDoc(request.resource.data);
      
      allow update: if isValidShareClicksDoc(request.resource.data) &&
                      request.resource.data.date == resource.data.date;
    }

    match /language_stats/{dateId} {
      allow read: if isAdmin();
      
      allow create: if isValidLanguageStatsDoc(request.resource.data);
      
      allow update: if isValidLanguageStatsDoc(request.resource.data) &&
                      request.resource.data.date == resource.data.date;
    }

    match /completion_stats/{dateId} {
      allow read: if isAdmin();
      
      allow create: if isValidCompletionStatsDoc(request.resource.data);
      
      allow update: if isValidCompletionStatsDoc(request.resource.data) &&
                      request.resource.data.date == resource.data.date;
    }

    match /discoveries/{dateId} {
      allow read: if isAdmin();
      
      allow create: if isValidDiscoveryStatsDoc(request.resource.data);
      
      allow update: if isValidDiscoveryStatsDoc(request.resource.data) &&
                      (!('date' in resource.data) || request.resource.data.date == resource.data.date);
    }

    match /infinite_daily_stats/{statsId} {
      allow read: if isAdmin();
      
      allow create: if isValidInfiniteDailyStatsDoc(request.resource.data);
      
      allow update: if isValidInfiniteDailyStatsDoc(request.resource.data) &&
                      (!('date' in resource.data) || request.resource.data.date == resource.data.date) &&
                      (!('gameId' in resource.data) || request.resource.data.gameId == resource.data.gameId) &&
                      (!('difficulty' in resource.data) || request.resource.data.difficulty == resource.data.difficulty);
    }

    match /infinite_runs/{runId} {
      allow read: if isAdmin();
      
      allow create: if isValidInfiniteRunDoc(request.resource.data);
      
      // Runs are immutable
      allow update, delete: if false;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
